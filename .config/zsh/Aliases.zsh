alias ls="ls -hF --color=auto --group-directories-first"
alias mkdir="mkdir -p"
alias mpd="mpd ~/.config/mpd/mpd.conf"
alias music='tmux new-session "tmux source-file ~/.config/ncmpcpp/tmux_session"'
alias p="sudo pacman"
alias ps="ps -u ${USER}"
alias systemctl='sudo systemctl'
alias wget='wget --hsts-file="~/.cache/wget-hsts"'
alias yay='yay --answerclean n --answerdiff n --answerupgrade y --noconfirm'
alias nvidia-settings='nvidia-settings --config="~/.config/nvidia/settings"'
alias grep='grep -i --color=auto'
